FROM nvidia/cuda:12.4.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

# system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv python3-pip \
        git curl apt-transport-https ca-certificates gnupg && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Google Cloud SDK
RUN curl -faSL https://packages.cloud.google.com/apt/doc/apt-key.gpg | apt-key add - && \
    echo "deb https://packages.cloud.google.com/apt cloud-sdk main" > /etc/apt/sources.list.d/google-cloud-sdk.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends google-cloud-cli && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Python dependencies for the full pipeline
RUN pip install --no-cache-dir --break-system-packages \
    torch==2.11.0 \
    transformers==4.45.0 \
    huggingface_hub==0.25.1 \
    llmcompressor==0.4.0 \
    lm_eval==0.4.4 \
    vllm==0.22.1 \
    guidellm==0.2.0 \
    google-cloud-storage==2.18.2 \
    google-cloud-secret-manager==2.20.2 \
    pyyaml==6.0.2 \
    openai==1.51.0

# Copy pipeline scripts
COPY scripts/ /opt/quantserve/scripts/
WORKDIR /opt/quantserve
